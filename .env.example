# ══════════════════════════════════════════════════════════════════
# Maya 2.0 — Environment Variables
# Copy this file to .env and fill in your values.
# All keys marked REQUIRED must be set. Others are optional.
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
# REQUIRED: Your public Railway URL (no trailing slash)
BASE_URL=https://your-app.up.railway.app

# Port — Railway sets this automatically; leave as-is
PORT=8000

# ── Anthropic (Claude) ────────────────────────────────────────────
# REQUIRED: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio ────────────────────────────────────────────────────────
# REQUIRED: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# Your Twilio phone number in E.164 format
TWILIO_PHONE_NUMBER=+16692489997

# Set to false during local dev to skip webhook signature validation
VALIDATE_TWILIO_SIG=true

# ── ElevenLabs (Voice) ────────────────────────────────────────────
# REQUIRED for ElevenLabs voice. Set USE_ELEVENLABS=false to use Twilio Polly instead.
ELEVENLABS_API_KEY=...
# Rachel voice (warm American female). Replace with your custom voice ID.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# true = use ElevenLabs (better voice), false = use Polly (lower latency)
USE_ELEVENLABS=true
# Max seconds to wait for ElevenLabs before falling back to Polly
ELEVENLABS_TIMEOUT_SECS=4.0

# ── Deepgram (Speech-to-Text) ─────────────────────────────────────
# Used for language detection. Twilio handles primary STT via <Gather>.
DEEPGRAM_API_KEY=...

# ── Restaurant Defaults ────────────────────────────────────────────
# Used when no restaurant matches the Twilio number called
RESTAURANT_ID=default
MANAGER_PHONE=6692489997
PREP_TIME_MINUTES=10
CATERING_THRESHOLD_DOLLARS=150

# ── Airtable (Optional — orders also saved to SQLite locally) ─────
AIRTABLE_API_KEY=...
AIRTABLE_BASE_ID=app...

# ── SendGrid (Optional — order confirmation emails) ───────────────
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
ORDER_NOTIFICATION_EMAIL=orders@yourrestaurant.com

# ── Slack (Optional — order + alert notifications) ────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_ORDERS_CHANNEL_ID=C...
SLACK_ALERT_CHANNEL_ID=C...

# ── Stripe (Optional — $500/month billing) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
